# Copy env_template.txt to .env.local (or run: powershell -File scripts/setup-local-env.ps1)
# Next.js loads .env.local automatically. Do not commit .env.local.

# Required for catalog + orders:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   (anon JWT, starts with eyJ)
# SUPABASE_SERVICE_ROLE_KEY=       (service_role JWT — required for placing orders)

# Required for M-Pesa/card checkout:
# PESAPAL_CONSUMER_KEY=
# PESAPAL_CONSUMER_SECRET=
# PESAPAL_ENV=sandbox
# PESAPAL_IPN_ID=

# Local dev:
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Live chat (off by default — set true on production server only; avoids Tawk console noise in dev)
# NEXT_PUBLIC_TAWK_ENABLED=true
